Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

%files
    # tarfile TDBP_gpu_Ubuntu22_04_20231201.tar.gz
    TDBP_gpu2 /opt/TDBP_gpu

%post
    export DEBIAN_FRONTEND=NONINTERACTIVE
    apt update -y
    apt install -y libfftw3-single3 libgdal30 libgomp1 liblapacke


%environment
    export PATH="/opt/TDBP_gpu/bin:/opt/TDBP_gpu/scripts:$PATH"

%labels
  author Jenny Fothergill <jennyfothergill@boisestate.edu>
  github.com/bsurc/container git rev={{GIT_REV}}
