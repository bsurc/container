Bootstrap: docker
From: nvidia/cuda:12.9.0-cudnn-devel-ubuntu24.04

%files
    # Built on borah-login2
    addons /opt/addons

%post
    export DEBIAN_FRONTEND=NONINTERACTIVE
    apt update -y
    apt install -y libfftw3-single3 libgdal34t64 libgomp1 liblapacke


%environment
    export PATH="/opt/addons:$PATH"

%labels
  author Jenny Fothergill <jennyfothergill@boisestate.edu>
  github.com/bsurc/container git rev={{GIT_REV}}
